{
  "name": "tmetric-mcp",
  "version": "1.0.0",
  "description": "MCP server for TMetric time tracking API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tmetric-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hcuffy/tmetric-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "tmetric",
    "time-tracking",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint:fix": "eslint src --fix",
    "lint": "eslint src",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm build && pnpm lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/node": "22.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "tsx": "4.0.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
